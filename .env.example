# Local Supabase stack (docker-compose). Safe defaults — change for any non-local use.
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# JWT secret shared by Postgres (for RLS JWT claims) and GoTrue.
# The anon/service keys below are JWTs signed by this secret.
# If you change one, change all three or regenerate via the supabase CLI.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Supabase Auth (gotrue) — exposed via kong on :54321
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.F_rDxRTPE8OU83L_CNgEGXfmirMXmMMugT29Cvc8ygQ
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTY0MTc2OTIwMCwiZXhwIjoxNzk5NTM1NjAwfQ.5z-pJI1qwZg1LE5yavGLqum65WOnnaaI5eZ3V00pLww

# Seed admin (created by pnpm db:seed via GoTrue admin API)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin12345
